<!--
  Miden patch — secondary-row button active pill background.
  Pale slate-blue #0F172A at 8% alpha. Mirrors iOS
  `NavbarSecondaryButton.activePillBg` = rgba(15, 23, 42, 0.08).
  Much more subtle than the main row's orange — icons + text stay
  heading-gray in both states; only the background fades in.
-->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="20dp" />
    <solid android:color="@color/navbar_secondary_active_bg" />
</shape>
